# Copy to .env.local and fill in. .env.local is gitignored.
# RapidAPI YouTube-audio (youtube-mp36) — serverless YouTube ingestion. When set,
# /api/transcribe uses it for YouTube; otherwise it falls back to local yt-dlp.
RAPIDAPI_KEY=
RAPIDAPI_YT_HOST=youtube-mp36.p.rapidapi.com

DEEPGRAM_API_KEY=
# Live argue/observe modes reuse DEEPGRAM_API_KEY. Optional overrides:
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
ANTHROPIC_ARGUE_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=
# IBIS extraction model. Defaults to claude-haiku-4-5 (cheap/fast).
# Override for harder debates, e.g. claude-opus-4-8 or claude-sonnet-4-6.
ANTHROPIC_MODEL=

# Optional: absolute paths to media tools (default to bare command names).
YT_DLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
FFMPEG_DIR=
